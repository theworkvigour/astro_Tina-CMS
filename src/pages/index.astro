---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import HeroCarousel from '~/components/HeroCarousel.astro';
import Features from '~/components/widgets/Features.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import ProductGrid from '~/components/widgets/ProductGrid.astro';
import { SITE, APP_PRODUCTS } from 'astrowind:config';
import { getProducts } from '~/utils/products';

import data from '~/data/pages/home.yaml';

const hero = data.hero ?? {};
const carousel = data.hero_carousel ?? {};
const features = data.features ?? {};
const featured = data.featured_products ?? {};
const workshop = data.content_workshop ?? {};
const steps = data.steps ?? {};
const blog = data.blog_latest ?? {};
const faqs = data.faqs ?? {};
const cta = data.cta ?? {};

const carouselSlides = Array.isArray(carousel.slides) ? carousel.slides : [];

const metadata = {
  title: `${SITE.name} — Premium inflatable boats, RIBs and engineered products`,
  description: SITE?.description,
  ignoreTitleTemplate: true,
};

const featuredProducts = APP_PRODUCTS?.isEnabled
  ? (await getProducts({ featured: true, limit: 4 }))
  : [];
---

<Layout metadata={metadata}>
  {carouselSlides.length > 0 ? (
    <HeroCarousel
      id="hero"
      slides={carouselSlides}
      autoplayInterval={typeof carousel.autoplay_interval === 'number' ? carousel.autoplay_interval : 5000}
    />
  ) : (
    <Hero
      id="hero"
      tagline={hero.tagline}
      title={hero.title}
      subtitle={hero.subtitle}
      actions={hero.actions}
      image={hero.image}
    />
  )}

  <Features
    id={features.id}
    tagline={features.tagline}
    title={features.title}
    subtitle={features.subtitle}
    columns={features.columns}
    items={features.items}
  />

  {
    featuredProducts.length > 0 && (
      <ProductGrid
        id={featured.id}
        title={featured.title}
        subtitle={featured.subtitle}
        linkText={featured.linkText}
        linkUrl={featured.linkUrl}
        products={featuredProducts}
      />
    )
  }

  <Content
    isReversed={workshop.isReversed}
    tagline={workshop.tagline}
    title={workshop.title}
    content={workshop.content}
    items={workshop.items}
    image={workshop.image}
  />

  <Steps
    title={steps.title}
    items={steps.items}
    image={steps.image}
  />

  <BlogLatestPosts title={blog.title} information={blog.information} />

  <FAQs
    title={faqs.title}
    subtitle={faqs.subtitle}
    columns={faqs.columns}
    items={faqs.items}
  />

  <CallToAction
    actions={cta.actions}
    title={cta.title}
    subtitle={cta.subtitle}
  />
</Layout>

---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import ProductGrid from '~/components/widgets/ProductGrid.astro';
import { SITE, APP_PRODUCTS } from 'astrowind:config';
import { getProducts } from '~/utils/products';

const metadata = {
  title: `${SITE.name} — Premium inflatable boats, RIBs and engineered products`,
  description: SITE?.description,
  ignoreTitleTemplate: true,
};

const featuredProducts = APP_PRODUCTS?.isEnabled
  ? (await getProducts({ featured: true, limit: 4 }))
  : [];
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->
  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Browse products',
        href: '/products',
        icon: 'tabler:shopping-bag',
      },
      { text: 'Learn more', href: '#features' },
    ]}
    image={{ src: '~/assets/images/hero-image.png', alt: `${SITE.name} hero image` }}
  >
    <Fragment slot="title">
      Engineered for the water. <br class="hidden sm:inline" />
      Built for <span class="text-accent dark:text-white">life on board</span>.
    </Fragment>

    <Fragment slot="subtitle">
      <span class="hidden sm:inline">
        <span class="font-semibold">{SITE.name}</span> designs and manufactures premium inflatable boats, RIBs and
        engineered products.</span
      >
      <span class="block mb-1 sm:hidden font-bold text-blue-600">{SITE.name}: built to perform.</span>
      Suitable for marine professionals, commercial operators, and enthusiasts who demand reliability and craftsmanship.
    </Fragment>
  </Hero>

  <!-- Features Widget *************** -->
  <Features
    id="features"
    tagline="Why Vectoflare"
    title="What you get with Vectoflare"
    subtitle="Decades of marine-engineering experience, distilled into a focused product line. Built tough, tested at sea, supported for life."
    items={[
      {
        title: 'Marine-grade materials',
        description: 'Heavy-duty PVC, Hypalon and aluminium hulls sourced for UV, abrasion and saltwater resistance.',
        icon: 'tabler:shield-check',
      },
      {
        title: 'Production-ready quality',
        description: 'Every hull is pressure-tested, every weld inspected. We ship only what we would put on the water ourselves.',
        icon: 'tabler:certificate',
      },
      {
        title: 'Modular by design',
        description: 'Customise tube layout, console position, fuel capacity and accessories to match your mission.',
        icon: 'tabler:layout-grid',
      },
      {
        title: 'Honest specifications',
        description: 'Real load ratings, real dimensions, real weight. No marketing inflation, ever.',
        icon: 'tabler:ruler-measure',
      },
      {
        title: 'Fast delivery & spare parts',
        description: 'Common models ship in days. Genuine spares and consumables in stock year-round.',
        icon: 'tabler:truck-delivery',
      },
      {
        title: 'Lifetime support',
        description: 'Direct line to our engineering team for technical questions, repairs and refit advice.',
        icon: 'tabler:lifebuoy',
      },
    ]}
  />

  <!-- Featured products -->
  {
    featuredProducts.length > 0 && (
      <ProductGrid
        id="featured"
        title="Featured products"
        subtitle="Hand-picked from our current catalog — the most popular models this season."
        linkText="View all products"
        linkUrl="/products"
        products={featuredProducts}
      />
    )
  }

  <!-- Content Widget **************** -->
  <Content
    isReversed
    tagline="Inside the workshop"
    title="From hull drawing to delivery, every step stays in-house"
    items={[
      {
        title: 'Designed by naval architects',
        description: 'Hull lines are drawn in-house and iterated through CFD analysis before the first prototype hits the water.',
      },
      {
        title: 'Welded and assembled in our own facility',
        description: 'Tube welding, console fit-out and rigging happen under one roof so we control quality at every step.',
      },
      {
        title: 'Tested at sea before shipment',
        description: 'Every model completes a multi-hour sea trial covering planing, turning, top speed and load handling.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1567899378494-47b22a2ae96a?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80',
      alt: 'Workshop',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Quality you can see, feel and measure</h3>
    </Fragment>
  </Content>

  <!-- Steps Widget ****************** -->
  <Steps
    title="From spec sheet to splash in five steps"
    items={[
      {
        title: 'Step 1: <span class="font-medium">Configure</span>',
        description: 'Pick a model, choose your options, request a quote online or by phone. Our team responds within one business day.',
        icon: 'tabler:list-numbers',
      },
      {
        title: 'Step 2: <span class="font-medium">Confirm</span>',
        description: 'We confirm specifications, lead time and total cost in writing. No surprises, no hidden fees.',
        icon: 'tabler:checks',
      },
      {
        title: 'Step 3: <span class="font-medium">Build</span>',
        description: 'Production kicks off in our workshop. We send progress photos at major milestones.',
        icon: 'tabler:tool',
      },
      {
        title: 'Step 4: <span class="font-medium">Deliver</span>',
        description: 'Cradled, shrink-wrapped and shipped by sea or air. Customs paperwork handled end to end.',
        icon: 'tabler:truck-loading',
      },
      {
        title: 'Step 5: <span class="font-medium">Support</span>',
        description: 'Two-year hull warranty plus lifetime technical support. Spares ship within 48 hours.',
        icon: 'tabler:headset',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1500627964684-141351970a7f?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80',
      alt: 'Manufacturing process',
    }}
  />

  <!-- BlogLatestPosts Widget ******* -->
  <BlogLatestPosts
    title="From the journal"
    information={`Articles, technical notes and case studies from the engineering team. 
                      New entries are added whenever a project is shipped, a standard is updated, or someone has a story worth telling.`}
  />

  <!-- FAQs Widget ******************* -->
  <FAQs
    title="Frequently asked questions"
    subtitle="The questions we hear most often. If yours is not here, drop us a line and we will get back to you fast."
    classes={{ container: 'max-w-4xl' }}
    items={[
      {
        title: 'Which model should I choose?',
        description:
          'It depends on your crew size, the water you run, and whether you prioritise speed, payload or fuel economy. Send us a short brief and we will recommend two or three models that fit.',
        icon: 'tabler:anchor',
      },
      {
        title: 'Do you ship internationally?',
        description:
          'Yes — we ship to over 40 countries. Sea freight is the most economical option for full boats; air freight is available for urgent orders.',
        icon: 'tabler:ship',
      },
      {
        title: 'What warranty do you provide?',
        description:
          'Two years on the hull, one year on accessories, lifetime on our welding. Warranty registration is included with every delivery.',
        icon: 'tabler:shield',
      },
      {
        title: 'Can I customise an existing model?',
        description:
          'Almost always. Console position, tube colour, seating layout, electronics and engine package can all be tailored. Custom hulls are quoted project by project.',
        icon: 'tabler:palette',
      },
      {
        title: 'Do you offer training and certification?',
        description:
          'For commercial operators we can arrange sea-trial training at our facility. Recreational customers get a free handover session on delivery.',
        icon: 'tabler:school',
      },
      {
        title: 'How do I get spare parts?',
        description:
          'Order through the contact page or call our spares line. Common items (valves, oars, pumps, repair kits) ship within 48 hours worldwide.',
        icon: 'tabler:settings',
      },
    ]}
  />

  <!-- CallToAction Widget *********** -->
  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Request a quote',
        href: '/contact',
        icon: 'tabler:message-circle',
      },
      { text: 'Browse the catalog', href: '/products' },
    ]}
  >
    <Fragment slot="title">
      Ready to spec your <br class="block sm:hidden" /><span class="sm:whitespace-nowrap">next boat</span>?
    </Fragment>

    <Fragment slot="subtitle">
      Tell us how you use your boat and we will recommend a model, options and a price in one business day.
    </Fragment>
  </CallToAction>
</Layout>

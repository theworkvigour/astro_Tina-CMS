---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Prices from '~/components/widgets/Pricing.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Steps from '~/components/widgets/Steps.astro';
import Features3 from '~/components/widgets/Features3.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { SITE } from 'astrowind:config';

const metadata = {
  title: `Pricing — ${SITE.name}`,
  description: `Transparent pricing for ${SITE.name} boats, accessories and service packages. No hidden fees.`,
};
---

<Layout metadata={metadata}>
  <HeroText
    tagline="Pricing"
    title="Honest pricing, on every model"
    subtitle="The price you see is the price you pay. Custom options are itemised up-front."
  />

  <Prices
    title="Service packages"
    subtitle="Pick a starting point — we will tailor a quote to your build"
    prices={[
      {
        title: 'recreational',
        subtitle: 'For private owners',
        price: 'from $4,800',
        period: 'one-time',
        items: [
          { description: 'Standard configuration' },
          { description: 'Sea-trial handover at our facility' },
          { description: 'Two-year hull warranty' },
          { description: 'Lifetime technical support' },
        ],
        callToAction: { target: '_blank', text: 'Browse recreational boats', href: '/products?category=inflatable' },
      },
      {
        title: 'commercial',
        subtitle: 'For working operators',
        price: 'from $18,500',
        period: 'one-time',
        items: [
          { description: 'Heavy-duty build options' },
          { description: 'Custom console and electronics' },
          { description: 'Three-year commercial warranty' },
          { description: '48-hour spares guarantee' },
          { description: 'Operator training included' },
        ],
        callToAction: { target: '_blank', text: 'Browse RIB boats', href: '/products?category=rib' },
        hasRibbon: true,
        ribbonTitle: 'popular',
      },
      {
        title: 'custom',
        subtitle: 'For unique projects',
        price: 'POA',
        period: 'project-based',
        items: [
          { description: 'Naval-architecture design' },
          { description: 'Engineering review' },
          { description: 'Milestone-based production' },
          { description: 'On-site delivery available' },
          { description: 'Dedicated project manager' },
        ],
        callToAction: { target: '_blank', text: 'Talk to engineering', href: '/contact' },
      },
    ]}
  />

  <Features3
    title="What you get on every build"
    subtitle="Standards, not upgrades."
    columns={2}
    items={[
      {
        title: 'Pressure-tested hull',
        description: 'Every hull passes a 30-minute pressure test before it leaves the workshop.',
        icon: 'tabler:gauge',
      },
      {
        title: 'Marine-grade fittings',
        description: '316 stainless fasteners, brass valves, UV-stable tube fabric.',
        icon: 'tabler:shield',
      },
      {
        title: 'Engine matched and rigged',
        description: 'Outboard engine is matched to hull and pre-rigged at our facility.',
        icon: 'tabler:engine',
      },
      {
        title: 'Sea trial report',
        description: 'Every boat comes with a signed sea-trial report covering performance and safety checks.',
        icon: 'tabler:clipboard-check',
      },
      {
        title: 'Owner handover pack',
        description: 'Owner manual, maintenance schedule, parts catalogue and contact card.',
        icon: 'tabler:book',
      },
      {
        title: 'Two-year warranty',
        description: 'Plus lifetime technical support from our engineering team.',
        icon: 'tabler:certificate',
      },
    ]}
    classes={{ container: 'max-w-5xl' }}
  />

  <Steps
    title="From quote to delivery"
    tagline="How it works"
    isReversed={true}
    items={[
      { title: 'Configure or call', icon: 'tabler:number-1' },
      { title: 'Receive itemised quote', icon: 'tabler:number-2' },
      { title: 'Confirm and pay deposit', icon: 'tabler:number-3' },
      { title: 'Production updates by photo', icon: 'tabler:number-4' },
      { title: 'Sea trial at our facility', icon: 'tabler:number-5' },
      { title: 'Worldwide delivery', icon: 'tabler:number-6' },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1536816579748-4ecb3f03d72a?ixlib=rb-4.0.3&auto=format&fit=crop&w=987&q=80',
      alt: 'Process',
    }}
  />

  <FAQs
    title="Pricing FAQs"
    subtitle="The questions we get most often about pricing and payment."
    columns={1}
    items={[
      {
        title: 'Are there hidden fees?',
        description: 'No. The quote we send itemises the boat, options, engine, freight, customs and tax. There are no extras at delivery.',
      },
      {
        title: 'Do you offer finance?',
        description: 'We do not finance directly, but we work with two preferred lenders for commercial operators in the EU, UK and APAC.',
      },
      {
        title: 'What payment methods do you accept?',
        description: 'Bank transfer for deposits and balances. Credit cards for deposits up to 10,000 USD.',
      },
      {
        title: 'Can I trade in my old boat?',
        description: 'Yes, on a case-by-case basis. Send us the make, model, year and current condition for an indicative trade-in value.',
      },
      {
        title: 'Do you charge for quotes?',
        description: 'Standard configuration quotes are free. Custom-engineering quotes for non-standard builds may carry a small design fee, refundable against the order.',
      },
    ]}
  />

  <CallToAction
    title="Ready to spec your boat?"
    subtitle="Use the product pages to configure a standard model, or send us a brief for a custom build."
    actions={[
      { variant: 'primary', text: 'Browse products', href: '/products' },
      { text: 'Talk to sales', href: '/contact' },
    ]}
  />
</Layout>

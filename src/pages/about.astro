---
import { getEntry } from 'astro:content';
import Features2 from '~/components/widgets/Features2.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Hero from '~/components/widgets/Hero.astro';
import Stats from '~/components/widgets/Stats.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Layout from '~/layouts/PageLayout.astro';
import { SITE } from 'astrowind:config';

import yamlData from '~/data/pages/about.yaml';

const locale = process.env.SITE_LOCALE || 'en';
const entry = await getEntry('about', 'index');
// eslint-disable-next-line @typescript-eslint/no-explicit-any
const ksData = (entry?.data as any)?.[locale] || (entry?.data as any)?.['en'] || {};
const data = Object.keys(ksData).length > 0 ? ksData : yamlData;

const hero = data.hero ?? {};
const stats = data.stats ?? {};
const wwb = data.features3_what_we_build ?? {};
const more = data.features3_more ?? {};
const values = data.steps2_values ?? {};
const milestones = data.steps2_milestones ?? {};
const locations = data.features2_locations ?? {};

const metadata = {
  title: `About ${SITE.name}`,
  description: `${SITE.name} designs and manufactures premium inflatable boats, RIBs and engineered products. Learn about our history, values and team.`,
};
---

<Layout metadata={metadata}>
  <Hero tagline={hero.tagline} image={hero.image} title={hero.title} subtitle={hero.subtitle} />

  <Stats title={stats.title} stats={stats.stats} />

  <Features3
    title={wwb.title}
    subtitle={wwb.subtitle}
    columns={wwb.columns}
    isBeforeContent={wwb.isBeforeContent}
    items={wwb.items}
  />

  <Features3
    columns={more.columns}
    isAfterContent={more.isAfterContent}
    items={more.items}
    image={more.image}
  />

  <Steps2
    title={values.title}
    subtitle={values.subtitle}
    items={values.items}
  />

  <Steps2
    title={milestones.title}
    subtitle={milestones.subtitle}
    isReversed={milestones.isReversed}
    items={milestones.items}
  />

  <Features2
    title={locations.title}
    tagline={locations.tagline}
    columns={locations.columns}
    items={locations.items}
  />
</Layout>

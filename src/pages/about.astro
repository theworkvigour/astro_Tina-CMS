---
import Features2 from '~/components/widgets/Features2.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Hero from '~/components/widgets/Hero.astro';
import Stats from '~/components/widgets/Stats.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Layout from '~/layouts/PageLayout.astro';
import { SITE } from 'astrowind:config';

const metadata = {
  title: `About ${SITE.name}`,
  description: `${SITE.name} designs and manufactures premium inflatable boats, RIBs and engineered products. Learn about our history, values and team.`,
};
---

<Layout metadata={metadata}>
  <Hero
    tagline="About us"
    image={{
      src: 'https://images.unsplash.com/photo-1500627964684-141351970a7f?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80',
      alt: `${SITE.name} workshop`,
    }}
  >
    <Fragment slot="title">
      Marine engineering, <br />
      built the <span class="text-accent dark:text-white">Vectoflare</span> way
    </Fragment>

    <Fragment slot="subtitle">
      We started in a coastal workshop with one boat and a stubborn belief: marine products should be engineered like
      they matter, because they do. Today we ship to over 40 countries, but every hull still passes through the same
      hands that started the company.
    </Fragment>
  </Hero>

  <Stats
    title="By the numbers"
    stats={[
      { title: 'Hulls delivered', amount: '2,400+' },
      { title: 'Countries shipped', amount: '40' },
      { title: 'Years of combined experience', amount: '60' },
      { title: 'Average warranty response (hours)', amount: '24' },
    ]}
  />

  <Features3
    title="What we build"
    subtitle="A focused product line that we know inside out — no half-finished experiments, no badge-engineering."
    columns={3}
    isBeforeContent={true}
    items={[
      {
        title: 'RIB boats',
        description:
          'Aluminium-hull RIBs from 3.3 m to 7.5 m. Designed for patrol, dive, fishing and family use.',
        icon: 'tabler:ship',
      },
      {
        title: 'Inflatable boats',
        description:
          'PVC and Hypalon inflatable dinghies from 2.4 m to 4.2 m. Light, tough and easy to stow.',
        icon: 'tabler:boat',
      },
      {
        title: 'Superyacht tenders',
        description:
          'Compact, high-spec RIBs custom-built to match the look of your mothership.',
        icon: 'tabler:crown',
      },
    ]}
  />

  <Features3
    columns={3}
    isAfterContent={true}
    items={[
      {
        title: 'Accessories',
        description: 'Oars, pumps, covers, dry-bags, fuel tanks and electronics. All matched to our boats.',
        icon: 'tabler:package',
      },
      {
        title: 'Refit & repair',
        description: 'In-house tube replacement, electronics retrofit and engine upgrades.',
        icon: 'tabler:tool',
      },
      {
        title: 'Custom builds',
        description: 'Project-by-project design for commercial, scientific and military customers.',
        icon: 'tabler:hammer',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1504384308090-c894fdcc538d?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80',
      alt: 'Custom boat build',
    }}
  />

  <Steps2
    title="Our values"
    subtitle="Three principles that have shaped every product since day one."
    items={[
      {
        title: 'Build like it carries your family',
        description: 'Every hull, weld and fastener is treated as if our own families will use it.',
        icon: 'tabler:heart',
      },
      {
        title: 'Engineer before we sell',
        description: 'If a spec is wrong, we change the spec — never the customer.',
        icon: 'tabler:settings',
      },
      {
        title: 'Support that outlasts the warranty',
        description: 'Twenty-year-old hulls still call us for spare parts, and we still pick up.',
        icon: 'tabler:headset',
      },
    ]}
  />

  <Steps2
    title="Milestones"
    subtitle="A short version of the Vectoflare story."
    isReversed={true}
    items={[
      {
        title: 'Founded in a coastal workshop',
        description: 'Started by two naval architects with a CNC mill and a stubborn idea.',
        icon: 'tabler:building-factory',
      },
      {
        title: 'First 1,000 hulls delivered',
        description: 'Reached in our seventh year, mostly through word of mouth and repeat customers.',
        icon: 'tabler:circle-check',
      },
      {
        title: 'International export programme',
        description: 'Now shipping to 40+ countries with localised support partners on five continents.',
        icon: 'tabler:world',
      },
    ]}
  />

  <Features2
    title="Our locations"
    tagline="Find us"
    columns={3}
    items={[
      {
        title: 'Headquarters & workshop',
        description: 'Coastal industrial park, building 4 — open Mon–Fri for visits by appointment.',
      },
      {
        title: 'EU service centre',
        description: 'Mediterranean port — refit, repair and warranty support for European customers.',
      },
      {
        title: 'APAC partner network',
        description: 'Authorised service partners in Australia, Japan, Singapore and Hong Kong.',
      },
    ]}
  />
</Layout>

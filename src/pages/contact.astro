---
export const prerender = false;
import { getEntry } from 'astro:content';
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import ContactUs from '~/components/widgets/Contact.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Map from '~/components/widgets/Map.astro';
import { SITE, I18N } from 'astrowind:config';

import yamlData from '~/data/pages/contact.yaml';
import branding from '~/data/site/branding.yaml';
import countryData from '~/data/site/countries.yaml';
import { generateChallenge, buildCookieValue, cookieName, cookieTtlSeconds } from '~/lib/contact-captcha';

const locale = I18N?.language || 'en';
const entry = await getEntry('contact', 'index');
// eslint-disable-next-line @typescript-eslint/no-explicit-any
const ksData = (entry?.data as any)?.[locale] || (entry?.data as any)?.['en'] || {};
const data = Object.keys(ksData).length > 0 ? ksData : yamlData;

const ht = data.hero_text ?? {};
const form = data.contact_form ?? {};
const other = data.features2_other_ways ?? {};

// eslint-disable-next-line @typescript-eslint/no-explicit-any
const countries = (countryData as any).countries?.map((c: any) => ({
  value: c.value,
  label: c.label?.[locale] || c.label?.en || c.value,
})) ?? [];

// eslint-disable-next-line @typescript-eslint/no-explicit-any
const countryCodes = (countryData as any).countries?.map((c: any) => ({
  code: c.tel,
  label: `${c.label?.[locale] || c.label?.en || c.value} ${c.tel}`,
})) ?? [];

const challenge = generateChallenge();
const cookie = buildCookieValue(challenge);
Astro.cookies.set(cookieName(), cookie.value, {
  httpOnly: true,
  secure: import.meta.env.PROD,
  sameSite: 'lax',
  path: '/',
  expires: cookie.expires,
  maxAge: cookieTtlSeconds(),
});

// eslint-disable-next-line @typescript-eslint/no-explicit-any
const brandingData: any = branding ?? {};
const resolvedEmailTo = (form.email_to && String(form.email_to).trim()) || (brandingData.contact_email_to as string) || '';

const metadata = {
  title: `Contact ${SITE.name}`,
  description: `Get in touch with ${SITE.name} — sales, support and partnership enquiries answered within one business day.`,
};
---

<Layout metadata={metadata}>
  <HeroText tagline={ht.tagline} title={ht.title} />

  <ContactUs
    id={form.id ?? 'form'}
    title={form.title}
    subtitle={form.subtitle}
    emailTo={resolvedEmailTo}
    submitButton={form.submit_button}
    successMessage={form.success_message}
    errorMessage={form.error_message}
    fields={form.fields ?? []}
    consent={form.consent}
    captcha={form.captcha ?? { label: 'Anti-spam' }}
    captchaQuestion={challenge.question}
    defaultCountryCode={form.default_country_code ?? '+1'}
    countryCodes={countryCodes}
    countries={countries}
  />

  <Features2
    title={other.title}
    columns={other.columns}
    items={other.items}
  />

  <Map
    title={data.map?.title}
    subtitle={data.map?.subtitle}
    address={data.map?.address}
    embedUrl={data.map?.embedUrl}
    latitude={data.map?.latitude}
    longitude={data.map?.longitude}
    zoom={data.map?.zoom}
  />
</Layout>

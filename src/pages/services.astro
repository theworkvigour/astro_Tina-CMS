---
import { getEntry } from 'astro:content';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Content from '~/components/widgets/Content.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Hero from '~/components/widgets/Hero.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import Layout from '~/layouts/PageLayout.astro';
import { SITE } from 'astrowind:config';

import yamlData from '~/data/pages/services.yaml';

const locale = process.env.SITE_LOCALE || 'en';
const entry = await getEntry('services', 'index');
// eslint-disable-next-line @typescript-eslint/no-explicit-any
const ksData = (entry?.data as any)?.[locale] || (entry?.data as any)?.['en'] || {};
const data = Object.keys(ksData).length > 0 ? ksData : yamlData;

const hero = data.hero ?? {};
const wwd = data.features2_what_we_do ?? {};
const service = data.content_service ?? {};
const testimonials = data.testimonials ?? {};
const cta = data.cta ?? {};

const metadata = {
  title: `Services — ${SITE.name}`,
  description: `${SITE.name} offers boat configuration, refit & repair, training, and worldwide delivery.`,
};
---

<Layout metadata={metadata}>
  <Hero
    tagline={hero.tagline}
    title={hero.title}
    subtitle={hero.subtitle}
    actions={hero.actions}
    image={hero.image}
  />

  <Features2
    title={wwd.title}
    subtitle={wwd.subtitle}
    columns={wwd.columns}
    items={wwd.items}
  />

  <Content
    isReversed={service.isReversed}
    items={service.items}
    image={service.image}
    content={service.content}
  />

  <Testimonials title={testimonials.title} testimonials={testimonials.testimonials} />

  <CallToAction
    actions={cta.actions}
    title={cta.title}
    subtitle={cta.subtitle}
  />
</Layout>

---
export const prerender = false;
import AdminLayout from '~/layouts/AdminLayout.astro';
import { verifySessionToken } from '~/lib/auth';
import { readTokenFromCookies } from '~/lib/token-store';

const session = Astro.cookies.get('ks-admin-session')?.value;
const verified = session ? verifySessionToken(session) : null;
if (!verified) return Astro.redirect('/login');
const token = readTokenFromCookies(Astro.cookies);
if (!token) return Astro.redirect('/keystatic/github-token');

const ALL_SECTION_TYPES = [
  'hero', 'hero_text', 'hero_carousel', 'features', 'features2', 'features3',
  'content', 'steps', 'steps2', 'stats', 'faqs', 'testimonials', 'pricing',
  'contact', 'cta', 'featured_products', 'blog_latest', 'map',
] as const;

const SECTION_LABELS: Record<string, string> = {
  hero: 'Hero (image + title + actions)',
  hero_text: 'Hero Text (title + content, no image)',
  hero_carousel: 'Hero Carousel (auto-rotating slides)',
  features: 'Features Grid (icon + title + description)',
  features2: 'Features 2-Column Grid',
  features3: 'Features 3 (with image + CTA)',
  content: 'Content Section (text + image)',
  steps: 'Steps (numbered process)',
  steps2: 'Steps 2 (alternating)',
  stats: 'Statistics (numbers)',
  faqs: 'FAQs',
  testimonials: 'Testimonials',
  pricing: 'Pricing Tiers',
  contact: 'Contact Form',
  cta: 'Call to Action',
  featured_products: 'Featured Products',
  blog_latest: 'Latest Blog Posts',
  map: 'Google Map',
};
---

<AdminLayout title="New Page" active="pages" username={verified?.username}>
  <div class="mb-6">
    <a href="/keystatic/pages" class="text-sm text-gray-500 hover:underline">← Back to Pages list</a>
    <h1 class="mt-2 text-2xl font-semibold">New Page</h1>
    <p class="mt-1 text-sm text-gray-500">Create a new page with a YAML content file, page definition, and locale placeholders.</p>
  </div>

  <form id="new-page-form" class="max-w-2xl space-y-6 pb-32">
    <div class="rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 p-6 space-y-4">
      <h2 class="text-base font-semibold">Page Info</h2>

      <div>
        <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Slug</label>
        <input id="f-slug" type="text" placeholder="e.g. privacy, terms, faq" class="w-full px-3 py-2 text-sm border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900" required />
        <p class="mt-1 text-xs text-gray-400">Used for the filename (privacy.yaml → /privacy). Lowercase letters, numbers, hyphens.</p>
      </div>

      <div>
        <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Label</label>
        <input id="f-label" type="text" placeholder="e.g. Privacy Policy" class="w-full px-3 py-2 text-sm border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900" required />
        <p class="mt-1 text-xs text-gray-400">Display name shown in the admin list.</p>
      </div>

      <div>
        <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Path (optional)</label>
        <input id="f-path" type="text" placeholder="/privacy" class="w-full px-3 py-2 text-sm border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900" />
        <p class="mt-1 text-xs text-gray-400">Site URL path. Defaults to /&lt;slug&gt;.</p>
      </div>
    </div>

    <div class="rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 p-6 space-y-4">
      <h2 class="text-base font-semibold">Sections / Widgets</h2>
      <p class="text-xs text-gray-500">Select the widgets this page should have. You can reorder and rename section keys.</p>

      <div id="sections-container" class="space-y-2">
        <div class="section-row flex items-center gap-2 bg-gray-50 dark:bg-gray-900 rounded-lg px-3 py-2">
          <span class="text-gray-400 cursor-grab text-sm">⠿</span>
          <input type="text" class="section-key w-32 px-2 py-1 text-xs font-mono border border-gray-300 dark:border-gray-700 rounded bg-white dark:bg-gray-900" value="hero" placeholder="key" />
          <select class="section-type flex-1 px-2 py-1 text-xs border border-gray-300 dark:border-gray-700 rounded bg-white dark:bg-gray-900">
            {ALL_SECTION_TYPES.map((t) => (
              <option value={t} selected={t === 'hero'}>{SECTION_LABELS[t]}</option>
            ))}
          </select>
          <input type="text" class="section-label flex-1 px-2 py-1 text-xs border border-gray-300 dark:border-gray-700 rounded bg-white dark:bg-gray-900" value="Hero" placeholder="Label" />
          <button type="button" class="remove-section text-red-500 hover:text-red-700 text-sm px-1" title="Remove section">✕</button>
        </div>
      </div>

      <button type="button" id="add-section-btn" class="text-xs text-blue-600 dark:text-blue-400 hover:underline">+ Add Section</button>
    </div>

    <div class="fixed bottom-0 left-0 right-0 bg-white dark:bg-gray-950 border-t border-gray-200 dark:border-gray-800 z-40">
      <div class="max-w-7xl mx-auto px-6 py-3 flex items-center justify-between gap-4">
        <div id="form-status" class="text-xs text-gray-500"></div>
        <div class="flex gap-2">
          <a href="/keystatic/pages" class="px-4 py-2 text-sm font-medium text-gray-600 dark:text-gray-300 hover:underline">Cancel</a>
          <button id="submit-btn" type="submit" class="px-5 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-md">Create Page</button>
        </div>
      </div>
    </div>
  </form>
</AdminLayout>

<script is:inline>
(function () {
  const container = document.getElementById('sections-container');
  const addBtn = document.getElementById('add-section-btn');
  const form = document.getElementById('new-page-form');
  const submitBtn = document.getElementById('submit-btn');
  const status = document.getElementById('form-status');

  if (addBtn && container) {
    addBtn.addEventListener('click', function () {
      const row = document.createElement('div');
      row.className = 'section-row flex items-center gap-2 bg-gray-50 dark:bg-gray-900 rounded-lg px-3 py-2';
      row.innerHTML =
        '<span class="text-gray-400 text-sm">\u283F</span>' +
        '<input type="text" class="section-key w-32 px-2 py-1 text-xs font-mono border border-gray-300 dark:border-gray-700 rounded bg-white dark:bg-gray-900" placeholder="key" />' +
        '<select class="section-type flex-1 px-2 py-1 text-xs border border-gray-300 dark:border-gray-700 rounded bg-white dark:bg-gray-900">' +
          Array.from(document.querySelectorAll('#sections-container .section-type option')).map(function (o) { return '<option value="' + o.value + '">' + o.text + '</option>'; }).join('') +
        '</select>' +
        '<input type="text" class="section-label flex-1 px-2 py-1 text-xs border border-gray-300 dark:border-gray-700 rounded bg-white dark:bg-gray-900" placeholder="Label" />' +
        '<button type="button" class="remove-section text-red-500 hover:text-red-700 text-sm px-1" title="Remove section">\u2715</button>';
      container.appendChild(row);
    });
  }

  if (container) {
    container.addEventListener('click', function (e) {
      var target = e.target;
      if (target instanceof Element && target.classList.contains('remove-section')) {
        var row = target.closest('.section-row');
        if (row && container.querySelectorAll('.section-row').length > 1) {
          row.remove();
        } else {
          status.textContent = 'At least one section is required.';
        }
      }
    });
  }

  if (form && submitBtn) {
    form.addEventListener('submit', async function (e) {
      e.preventDefault();
      var slug = document.getElementById('f-slug');
      var label = document.getElementById('f-label');
      var path = document.getElementById('f-path');
      if (!slug || !label) return;

      var s = slug.value.trim().toLowerCase();
      var l = label.value.trim();
      if (!s || !/^[a-z][a-z0-9_-]*$/.test(s)) {
        if (status) status.textContent = 'Slug must start with a letter and contain only lowercase letters, numbers, hyphens, and underscores.';
        return;
      }
      if (!l) {
        if (status) status.textContent = 'Label is required.';
        return;
      }

      var sections = [];
      container.querySelectorAll('.section-row').forEach(function (row) {
        var key = row.querySelector('.section-key');
        var type = row.querySelector('.section-type');
        var label = row.querySelector('.section-label');
        var k = key ? key.value.trim() : '';
        var t = type ? type.value : '';
        var lbl = label ? label.value.trim() || k : k;
        if (k && t) sections.push({ key: k, type: t, label: lbl });
      });

      if (sections.length === 0) {
        if (status) status.textContent = 'At least one section is required.';
        return;
      }

      var p = path ? path.value.trim() || '/' + s : '/' + s;

      submitBtn.disabled = true;
      submitBtn.textContent = 'Creating...';
      if (status) status.textContent = 'Creating page...';

      try {
        var res = await fetch('/api/admin/pages', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            slug: s,
            label: l,
            path: p,
            permalink: p,
            sections: sections,
          }),
        });
        var data = await res.json();
        if (data.success) {
          if (status) status.textContent = 'Page created! Redirecting...';
          setTimeout(function () { window.location.href = '/keystatic/pages/' + encodeURIComponent(s); }, 1000);
        } else {
          if (status) { status.textContent = data.error || 'Failed'; status.className = 'text-xs text-red-600'; }
          submitBtn.disabled = false;
          submitBtn.textContent = 'Create Page';
        }
      } catch (e) {
        if (status) { status.textContent = 'Network error'; status.className = 'text-xs text-red-600'; }
        submitBtn.disabled = false;
        submitBtn.textContent = 'Create Page';
      }
    });
  }
})();
</script>

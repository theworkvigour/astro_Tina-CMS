---
export const prerender = false;
import AdminLayout from '~/layouts/AdminLayout.astro';
import { verifySessionToken } from '~/lib/auth';
import { readTokenFromCookies } from '~/lib/token-store';
import { GitHubClient } from '~/lib/github';

const session = Astro.cookies.get('ks-admin-session')?.value;
const verified = session ? verifySessionToken(session) : null;
if (!verified) return Astro.redirect('/login');

const token = readTokenFromCookies(Astro.cookies);
let githubUser: { login: string; name: string | null; avatarUrl: string } | null = null;
if (token) {
  try {
    const client = new GitHubClient(token);
    const user = await client.verifyToken();
    githubUser = { login: user.login, name: user.name, avatarUrl: user.avatar_url };
  } catch {
    githubUser = null;
  }
}

let counts = { posts: 0, products: 0, pages: 0, nav: 0, submissions: 0 };
if (token) {
  try {
    const client = new GitHubClient(token);
    const [posts, products, pages, site, contactFiles] = await Promise.all([
      client.listFiles('src/data/post/'),
      client.listFiles('src/data/product/'),
      client.listFiles('src/data/pages/'),
      client.listFiles('src/data/site/'),
      client.listFiles('src/data/contact/').catch(() => []),
    ]);
    counts = {
      posts: posts.filter((f) => /\.(md|mdx)$/i.test(f.name)).length,
      products: products.filter((f) => /\.(md|mdx)$/i.test(f.name)).length,
      pages: pages.filter((f) => /\.(ya?ml)$/i.test(f.name)).length,
      nav: site.filter((f) => /\.(ya?ml)$/i.test(f.name)).length,
      submissions: contactFiles.filter((f) => /submissions\.enc\.json$/i.test(f.name)).length > 0 ? 1 : 0,
    };
  } catch {
    counts = { posts: 0, products: 0, pages: 0, nav: 0, submissions: 0 };
  }
}
---
<AdminLayout title="Dashboard" active="dashboard" username={verified?.username}>
  {!token && (
    <div class="mb-6 rounded-lg border border-amber-300 bg-amber-50 dark:bg-amber-950/30 dark:border-amber-800 p-4">
      <h2 class="text-base font-semibold text-amber-900 dark:text-amber-200">GitHub Token Required</h2>
      <p class="mt-1 text-sm text-amber-800 dark:text-amber-300">
        All content edits go through the GitHub repository. Please generate a Personal Access Token with <code class="px-1 py-0.5 bg-amber-100 dark:bg-amber-900 rounded">repo</code> scope, then paste it on the
        <a href="/keystatic/github-token" class="font-medium underline">Connect GitHub</a> page.
      </p>
    </div>
  )}

  {token && githubUser && (
    <div class="mb-6 rounded-lg border border-green-300 bg-green-50 dark:bg-green-950/30 dark:border-green-800 p-4 flex items-center justify-between gap-4">
      <div class="flex items-center gap-3">
        <img src={githubUser.avatarUrl} alt="" class="w-10 h-10 rounded-full" />
        <div>
          <div class="text-sm font-medium text-green-900 dark:text-green-200">
            Connected as <span class="font-mono">{githubUser.login}</span>
          </div>
          <div class="text-xs text-green-700 dark:text-green-400">All changes are committed to theworkvigour/astro_Tina-CMS</div>
        </div>
      </div>
      <a href="/keystatic/github-token" class="text-sm text-green-800 dark:text-green-300 hover:underline">Change Token</a>
    </div>
  )}

  <div class="mb-8 rounded-xl border-2 border-blue-200 dark:border-blue-800 bg-blue-50 dark:bg-blue-950/30 p-6">
    <h2 class="text-base font-semibold text-blue-900 dark:text-blue-200">Content — YAML / Markdown Editors</h2>
    <p class="mt-1 text-sm text-blue-700 dark:text-blue-300">
      Edit pages, posts, products, navigation, branding directly via GitHub API.
    </p>
    <div class="mt-4 flex flex-wrap gap-3">
      <a href="/keystatic/posts" class="text-sm text-blue-600 dark:text-blue-400 hover:underline">Posts</a>
      <span class="text-blue-300 dark:text-blue-700">|</span>
      <a href="/keystatic/products" class="text-sm text-blue-600 dark:text-blue-400 hover:underline">Products</a>
      <span class="text-blue-300 dark:text-blue-700">|</span>
      <a href="/keystatic/pages" class="text-sm text-blue-600 dark:text-blue-400 hover:underline">Pages</a>
      <span class="text-blue-300 dark:text-blue-700">|</span>
      <a href="/keystatic/navigation" class="text-sm text-blue-600 dark:text-blue-400 hover:underline">Navigation</a>
      <span class="text-blue-300 dark:text-blue-700">|</span>
      <a href="/keystatic/branding" class="text-sm text-blue-600 dark:text-blue-400 hover:underline">Branding</a>
      <span class="text-blue-300 dark:text-blue-700">|</span>
      <a href="/keystatic/contact-submissions" class="text-sm text-blue-600 dark:text-blue-400 hover:underline">Submissions</a>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <a href="/keystatic/posts" class="block rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 p-6 hover:border-blue-400 transition">
      <div class="text-sm uppercase tracking-wide text-gray-500">Posts</div>
      <div class="mt-2 text-3xl font-semibold">{counts.posts}</div>
      <div class="mt-4 text-sm text-blue-600 dark:text-blue-400">Manage Posts →</div>
    </a>
    <a href="/keystatic/products" class="block rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 p-6 hover:border-blue-400 transition">
      <div class="text-sm uppercase tracking-wide text-gray-500">Products</div>
      <div class="mt-2 text-3xl font-semibold">{counts.products}</div>
      <div class="mt-4 text-sm text-blue-600 dark:text-blue-400">Manage Products →</div>
    </a>
    <a href="/keystatic/pages" class="block rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 p-6 hover:border-blue-400 transition">
      <div class="text-sm uppercase tracking-wide text-gray-500">Pages</div>
      <div class="mt-2 text-3xl font-semibold">{counts.pages}</div>
      <div class="mt-4 text-sm text-blue-600 dark:text-blue-400">Edit Page Content →</div>
    </a>
    <a href="/keystatic/navigation" class="block rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 p-6 hover:border-blue-400 transition">
      <div class="text-sm uppercase tracking-wide text-gray-500">Navigation / Footer</div>
      <div class="mt-2 text-3xl font-semibold">{counts.nav}</div>
      <div class="mt-4 text-sm text-blue-600 dark:text-blue-400">Edit Navigation & Social Links →</div>
    </a>
    <a href="/keystatic/branding" class="block rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 p-6 hover:border-blue-400 transition">
      <div class="text-sm uppercase tracking-wide text-gray-500">Branding / Logo</div>
      <div class="mt-2 text-3xl font-semibold">—</div>
      <div class="mt-4 text-sm text-blue-600 dark:text-blue-400">Site Name, Logo, Copyright →</div>
    </a>
    <a href="/keystatic/contact-submissions" class="block rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 p-6 hover:border-blue-400 transition">
      <div class="text-sm uppercase tracking-wide text-gray-500">Submissions</div>
      <div class="mt-2 text-3xl font-semibold">{counts.submissions ? '✓' : '—'}</div>
      <div class="mt-4 text-sm text-blue-600 dark:text-blue-400">View Encrypted Submissions →</div>
    </a>
    <a href="/keystatic/link-refactor" class="block rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 p-6 hover:border-blue-400 transition">
      <div class="text-sm uppercase tracking-wide text-gray-500">Links</div>
      <div class="mt-2 text-3xl font-semibold">⚙</div>
      <div class="mt-4 text-sm text-blue-600 dark:text-blue-400">Batch Rename URLs / Check Broken Links →</div>
    </a>
  </div>

  <div class="mt-10 rounded-lg border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 p-6">
    <h2 class="text-base font-semibold">Usage</h2>
    <ul class="mt-3 text-sm text-gray-600 dark:text-gray-300 space-y-1 list-disc list-inside">
      <li>All changes are pushed via GitHub API to the <code class="font-mono">main</code> branch; Cloudflare auto-triggers rebuild</li>
      <li>Blog and product pages update immediately after deploy (typically 1-2 minutes)</li>
      <li>History & rollback: check the <a class="text-blue-600 hover:underline" href="https://github.com/theworkvigour/astro_Tina-CMS/commits/main/src/data" target="_blank" rel="noopener">commit history</a> in GitHub</li>
      <li>Global site settings (SEO defaults, organization info) live in <code class="font-mono">src/config.yaml</code> in the repo</li>
      <li>Per-locale builds: set <code class="font-mono">SITE_LOCALE</code> env var (en/fr/de/es/pt/zh) to generate locale-specific output</li>
      <li>Multilingual content (<code class="font-mono">src/content/*/index.json</code>) can be edited directly in GitHub or via a local <code class="font-mono">npx keystatic dev</code> session</li>
    </ul>
  </div>
</AdminLayout>

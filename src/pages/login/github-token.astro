---
export const prerender = false;

import Layout from '~/layouts/Layout.astro';
import { verifySessionToken } from '~/lib/auth';

const sessionCookie = Astro.cookies.get('ks-admin-session')?.value;
const session = sessionCookie ? verifySessionToken(sessionCookie) : null;

if (!session) {
  return Astro.redirect('/login');
}

const existingToken = Astro.cookies.get('keystatic-gh-access-token')?.value;
if (existingToken) {
  return Astro.redirect('/keystatic');
}
---

<Layout>
  <main class="min-h-screen flex items-center justify-center bg-gray-100 dark:bg-gray-900 px-4">
    <div class="w-full max-w-md">
      <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-xl p-8">
        <div class="text-center mb-6">
          <h1 class="text-xl font-bold text-gray-900 dark:text-white">关联 GitHub</h1>
          <p class="text-gray-500 dark:text-gray-400 mt-2 text-sm">请输入 GitHub Personal Access Token 以启用内容管理</p>
        </div>

        <form id="token-form" class="space-y-5">
          <div id="message" class="hidden rounded-lg p-3 text-sm"></div>

          <div>
            <label for="token" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
              GitHub Personal Access Token
            </label>
            <input
              type="password"
              id="token"
              name="token"
              required
              placeholder="ghp_xxxxxxxxxxxxxxxxxxxx"
              class="w-full px-4 py-2.5 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition"
            />
            <p class="text-xs text-gray-500 dark:text-gray-400 mt-2">
              需要 repo 权限，在
              <a href="https://github.com/settings/tokens" target="_blank" rel="noopener" class="text-blue-600 dark:text-blue-400 hover:underline">GitHub Token 设置</a>
              中创建
            </p>
          </div>

          <button
            type="submit"
            class="w-full py-2.5 px-4 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-lg transition duration-150 ease-in-out focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 dark:focus:ring-offset-gray-800"
          >验证并保存</button>
        </form>

        <div class="mt-6 text-center">
          <a href="/api/auth/logout" class="text-sm text-red-600 dark:text-red-400 hover:underline">返回登录</a>
        </div>
      </div>
    </div>
  </main>

  <script>
    document.getElementById('token-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target as HTMLFormElement;
      const btn = form.querySelector('button') as HTMLButtonElement;
      const msg = document.getElementById('message')!;
      const token = (document.getElementById('token') as HTMLInputElement).value.trim();

      btn.disabled = true;
      btn.textContent = '验证中...';
      msg.classList.add('hidden');

      try {
        const res = await fetch('/api/auth/set-github-token', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ token }),
        });

        const data = await res.json();

        if (res.ok && data.success) {
          window.location.href = '/keystatic';
        } else {
          msg.className = 'rounded-lg p-3 text-sm bg-red-50 dark:bg-red-900/30 text-red-600 dark:text-red-400';
          msg.textContent = data.error || '验证失败，请检查 Token';
          msg.classList.remove('hidden');
        }
      } catch {
        msg.className = 'rounded-lg p-3 text-sm bg-red-50 dark:bg-red-900/30 text-red-600 dark:text-red-400';
        msg.textContent = '网络错误，请重试';
        msg.classList.remove('hidden');
      } finally {
        btn.disabled = false;
        btn.textContent = '验证并保存';
      }
    });
  </script>
</Layout>

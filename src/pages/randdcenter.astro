---
import Layout from '~/layouts/PageLayout.astro';
import { SITE } from 'astrowind:config';

const metadata = {
  title: `R&D Center — ${SITE.name}`,
  description: 'Research & Development Center — Innovation is our Faith. Hot forging, CNC machining, mold design, and more.',
};

const labs = [
  {
    image: 'https://static.wixstatic.com/media/e4fcb4_ad3747db80cd4ca98ad13bbc8237281e~mv2.jpg',
    title: 'Forge Lab',
    description: 'Concentrate on hot die forging and related heat treatment.',
    href: '#',
  },
  {
    image: 'https://static.wixstatic.com/media/e4fcb4_18b99234a97544129268c144ceeda516~mv2.jpg',
    title: 'Mold Design',
    description: 'Mold design for metal working industry.',
    href: '#',
  },
  {
    image: 'https://static.wixstatic.com/media/e4fcb4_b970990257ab462390be32fbb4b5e782~mv2.jpg',
    title: 'Product Design',
    description: 'Product shape, dimension design based on product actual application.',
    href: '#',
  },
  {
    image: 'https://static.wixstatic.com/media/e4fcb4_2dafc0053c124c18a6c75b1b9dddd8fe~mv2.png',
    title: 'CNC Center',
    description: 'Horizontal and vertical machining centers in a variety of sizes and configurations to meet different manufacturing needs.',
    href: '#',
  },
  {
    image: 'https://static.wixstatic.com/media/e4fcb4_2e13e227ea5b4b7494b73b4e439a0689~mv2.jpg',
    title: 'Cast Lab',
    description: 'Provides research and production in casting processing of metals and alloys.',
    href: '#',
  },
  {
    image: 'https://static.wixstatic.com/media/e4fcb4_9e604628c83747dfbb33d30404ab5b73~mv2.png',
    title: 'Automated Welding',
    description: 'Provides professional manual welding and robotic welding work.',
    href: '#',
  },
];
---

<Layout metadata={metadata}>
  <section class="px-6 sm:px-6 py-16 sm:py-20 lg:py-24 mx-auto max-w-5xl text-center">
    <p class="text-sm font-semibold text-primary uppercase tracking-wider">XLOY</p>
    <h1 class="mt-3 text-4xl md:text-5xl font-bold">Research & Development Center</h1>
    <p class="mt-3 text-lg text-muted">Innovation is our Faith</p>
  </section>

  <section class="px-6 sm:px-6 pb-16 mx-auto max-w-4xl">
    <p class="text-muted leading-relaxed">
      We work in a wide variety of manufacturing techniques, including punching, hot-forging, CNC machining,
      laser cutting, heat treatment, etc., providing bespoke parts for a variety of industrial and commercial
      uses, from design and development right through to product completion.
    </p>
    <p class="text-muted leading-relaxed mt-6">
      It is also our goal to preserve and improve our leading position in the future. Our R&D work significantly
      increases our chances of achieving this goal, so we are constantly developing and testing products from
      every imaginable application, such as tensile machines, low temperature impact machines, metallographic
      structure analysis, and so on, for the necessary static and dynamic tests.
    </p>
  </section>

  <section class="px-6 sm:px-6 pb-20 mx-auto max-w-6xl">
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {labs.map((lab) => (
        <div class="rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 overflow-hidden shadow-sm hover:shadow-md transition-shadow">
          <div class="aspect-[4/3] overflow-hidden bg-gray-100 dark:bg-gray-900">
            <img
              src={lab.image}
              alt={lab.title}
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
          <div class="p-5">
            <h3 class="text-lg font-bold">{lab.title}</h3>
            <p class="mt-2 text-sm text-muted">{lab.description}</p>
            <a
              href={lab.href}
              class="mt-3 inline-flex items-center text-sm font-semibold text-primary hover:underline"
            >
              View More &rarr;
            </a>
          </div>
        </div>
      ))}
    </div>
  </section>
</Layout>

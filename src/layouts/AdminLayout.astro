---
import '~/assets/styles/tailwind.css';

interface Props {
  title: string;
  active: 'dashboard' | 'posts' | 'products' | 'pages' | 'navigation' | 'branding' | 'settings';
  username?: string;
}

const { title, active, username } = Astro.props;

const tabs = [
  { id: 'dashboard', href: '/keystatic', label: 'Dashboard' },
  { id: 'posts', href: '/keystatic/posts', label: '博客文章 / Posts' },
  { id: 'products', href: '/keystatic/products', label: '产品 / Products' },
  { id: 'pages', href: '/keystatic/pages', label: '网页内容 / Pages' },
  { id: 'navigation', href: '/keystatic/navigation', label: '导航 / Nav' },
  { id: 'branding', href: '/keystatic/branding', label: '品牌 / Branding' },
] as const;
---
<!doctype html>
<html lang="zh-CN" class="h-full">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{title} — Vectoflare Admin</title>
  </head>
  <body class="h-full bg-gray-50 text-gray-900 dark:bg-gray-900 dark:text-gray-100 font-sans antialiased">
    <header class="border-b border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950">
      <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between gap-6">
        <div class="flex items-center gap-3">
          <a href="/keystatic" class="text-lg font-semibold tracking-tight">Vectoflare Admin</a>
          <span class="text-xs text-gray-400">/ GitHub-backed CMS</span>
        </div>
        <nav class="flex items-center gap-1">
          {tabs.map((t) => (
            <a
              href={t.href}
              class={`px-3 py-1.5 text-sm rounded-md ${active === t.id ? 'bg-blue-50 dark:bg-blue-950 text-blue-700 dark:text-blue-300' : 'text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800'}`}
            >
              {t.label}
            </a>
          ))}
        </nav>
        <div class="flex items-center gap-3 text-sm">
          {username && <span class="text-gray-500 dark:text-gray-400">{username}</span>}
          <a href="/login/change-password" class="text-gray-600 dark:text-gray-300 hover:underline">修改密码</a>
          <a href="/api/auth/logout" class="text-red-600 dark:text-red-400 hover:underline">退出登录</a>
        </div>
      </div>
    </header>
    <main class="max-w-7xl mx-auto px-6 py-8">
      <slot />
    </main>
    <div id="toast-container" class="fixed top-4 right-4 z-50 flex flex-col gap-2 pointer-events-none"></div>
    <script is:inline>
      (function () {
        function ensureContainer() {
          let el = document.getElementById('toast-container');
          if (!el) {
            el = document.createElement('div');
            el.id = 'toast-container';
            el.className = 'fixed top-4 right-4 z-50 flex flex-col gap-2 pointer-events-none';
            document.body.appendChild(el);
          }
          return el;
        }
        window.__adminToast = function (msg, type) {
          const el = ensureContainer();
          const div = document.createElement('div');
          const bg =
            type === 'error'
              ? 'bg-red-600 text-white'
              : type === 'success'
                ? 'bg-green-600 text-white'
                : 'bg-gray-800 text-white';
          div.className = `${bg} px-4 py-2 rounded-md shadow-lg text-sm pointer-events-auto transition-opacity duration-300`;
          div.textContent = msg;
          el.appendChild(div);
          setTimeout(() => {
            div.style.opacity = '0';
            setTimeout(() => div.remove(), 300);
          }, 3500);
        };
      })();
    </script>
  </body>
</html>

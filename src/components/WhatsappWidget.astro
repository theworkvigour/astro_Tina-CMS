---
import branding from '~/data/site/branding.yaml';

const phone = (branding?.whatsapp_number || '').toString().replace(/[^\d+]/g, '');
const defaultMessage = (branding?.whatsapp_default_message || '').toString();
---

{phone && (
  <div data-whatsapp-widget class="fixed bottom-4 right-4 z-50 flex flex-col items-end gap-2">
    <div
      data-whatsapp-panel
      class="hidden w-80 max-w-[calc(100vw-2rem)] bg-white dark:bg-gray-950 rounded-2xl shadow-2xl border border-gray-200 dark:border-gray-800 overflow-hidden"
    >
      <div class="bg-green-600 text-white px-4 py-3 flex items-center gap-3">
        <div class="w-10 h-10 rounded-full bg-white/20 flex items-center justify-center shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413"/>
          </svg>
        </div>
        <div class="flex-1 min-w-0">
          <div class="font-semibold text-sm">在线客服</div>
          <div class="text-xs text-white/80">通常几分钟内回复</div>
        </div>
        <button
          type="button"
          data-whatsapp-close
          aria-label="关闭"
          class="text-white/80 hover:text-white"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>
      </div>
      <div class="p-4 space-y-3">
        <div class="bg-gray-100 dark:bg-gray-900 rounded-lg p-3 text-sm text-gray-700 dark:text-gray-300">
          你好 👋 有什么可以帮到你的吗?直接在下方输入消息,点击发送会跳转到 WhatsApp。
        </div>
        <textarea
          data-whatsapp-input
          rows="3"
          placeholder="输入消息..."
          class="w-full px-3 py-2 text-sm border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 resize-none"
        >{defaultMessage}</textarea>
        <button
          type="button"
          data-whatsapp-send
          class="w-full bg-green-600 hover:bg-green-700 text-white text-sm font-medium py-2 rounded-md"
        >
          通过 WhatsApp 发送
        </button>
      </div>
    </div>
    <button
      type="button"
      data-whatsapp-toggle
      aria-label="打开 WhatsApp 聊天"
      class="w-14 h-14 rounded-full bg-green-500 hover:bg-green-600 text-white shadow-lg flex items-center justify-center transition-transform hover:scale-105"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413"/>
      </svg>
    </button>
  </div>
)}

<script is:inline define:vars={{ phone }}>
  (function () {
    if (!phone) return;
    const widget = document.querySelector('[data-whatsapp-widget]');
    if (!widget) return;
    const toggle = widget.querySelector('[data-whatsapp-toggle]');
    const panel = widget.querySelector('[data-whatsapp-panel]');
    const close = widget.querySelector('[data-whatsapp-close]');
    const send = widget.querySelector('[data-whatsapp-send]');
    const input = widget.querySelector('[data-whatsapp-input]');
    if (!toggle || !panel || !close || !send || !input) return;

    function open() { panel.classList.remove('hidden'); toggle.setAttribute('aria-expanded', 'true'); }
    function closePanel() { panel.classList.add('hidden'); toggle.setAttribute('aria-expanded', 'false'); }
    toggle.addEventListener('click', function () { panel.classList.contains('hidden') ? open() : closePanel(); });
    close.addEventListener('click', closePanel);
    send.addEventListener('click', function () {
      const msg = (input.value || '').trim();
      const url = 'https://wa.me/' + encodeURIComponent(phone) + (msg ? '?text=' + encodeURIComponent(msg) : '');
      window.open(url, '_blank', 'noopener,noreferrer');
    });
  })();
</script>

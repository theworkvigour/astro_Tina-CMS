---
export interface Props {
  id?: string;
  title?: string;
  subtitle?: string;
  address?: string;
  embedUrl?: string;
  latitude?: string;
  longitude?: string;
  zoom?: number;
}

const {
  id = 'map',
  title,
  subtitle,
  address,
  embedUrl = '',
  latitude = '',
  longitude = '',
  zoom = 15,
} = Astro.props;

const mapSrc = embedUrl || (latitude && longitude
  ? `https://www.google.com/maps/embed/v1/view?key=&center=${latitude},${longitude}&zoom=${zoom}`
  : '');
---

<section id={id} class="relative scroll-mt-16">
  {(title || subtitle) && (
    <div class="max-w-7xl mx-auto px-4 pt-12 md:pt-20 text-center">
      {title && <h2 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white">{title}</h2>}
      {subtitle && <p class="mt-2 text-gray-500 dark:text-gray-400">{subtitle}</p>}
    </div>
  )}
  <div class="max-w-7xl mx-auto px-4 py-8 md:py-12">
    {address && (
      <div class="flex items-center gap-2 mb-4 text-sm text-gray-600 dark:text-gray-400">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        <span>{address}</span>
      </div>
    )}
    {mapSrc ? (
      <div class="w-full h-[300px] md:h-[400px] rounded-xl overflow-hidden border border-gray-200 dark:border-gray-700">
        <iframe
          src={mapSrc}
          width="100%"
          height="100%"
          style="border:0"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title={title || 'Company location'}
        ></iframe>
      </div>
    ) : (
      <div class="w-full h-[300px] md:h-[400px] rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-100 dark:bg-gray-800 flex items-center justify-center text-gray-400 text-sm">
        {latitude && longitude ? 'Google Maps API key required' : 'No map location configured'}
      </div>
    )}
  </div>
</section>

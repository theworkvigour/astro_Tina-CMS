---
const { messages = [] } = Astro.props;
const defaultMessages = [
  { tag: 'NEW', text: 'Welcome to Vectoflare', href: '/' },
  { tag: 'CMS', text: 'Editorial admin: /keystatic', href: '/keystatic' },
];
const items = messages.length ? messages : defaultMessages;
---

<div
  class="text-sm bg-slate-900 text-slate-300 dark:bg-transparent dark:border-b dark:border-slate-800 dark:text-slate-400 hidden md:flex gap-4 overflow-hidden px-3 py-2 relative text-ellipsis whitespace-nowrap"
>
  {
    items.map((m) => (
      <a href={m.href} class="hover:underline dark:text-slate-400 font-medium inline-flex items-center gap-1.5">
        <span class="bg-white/20 dark:bg-slate-700 text-slate-100 dark:text-slate-300 font-semibold px-1.5 py-0.5 text-[10px] inline-block uppercase tracking-wider">
          {m.tag}
        </span>
        <span>{m.text}</span>
      </a>
    ))
  }
</div>

---
const { messages = [], showLogin = true } = Astro.props;
const defaultMessages = [
  { tag: 'NEW', text: 'Welcome to Vectoflare', href: '/' },
  { tag: 'CMS', text: 'Editorial admin: /keystatic', href: '/keystatic' },
];
const items = messages.length ? messages : defaultMessages;
---

<div
  class="text-sm bg-slate-900 text-slate-300 dark:bg-slate-900 dark:text-slate-300 flex gap-4 overflow-hidden px-3 py-2 relative text-ellipsis whitespace-nowrap items-center"
>
  <div class="flex-1 flex gap-4 overflow-hidden">
    {
      items.map((m) => (
        <a href={m.href} class="hover:underline font-medium inline-flex items-center gap-1.5">
          <span class="bg-white/20 text-slate-100 font-semibold px-1.5 py-0.5 text-[10px] inline-block uppercase tracking-wider">
            {m.tag}
          </span>
          <span>{m.text}</span>
        </a>
      ))
    }
  </div>
  {showLogin && (
    <a
      href="/keystatic"
      class="hover:underline font-semibold text-slate-100 inline-flex items-center gap-1 shrink-0"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4" />
        <polyline points="10 17 15 12 10 7" />
        <line x1="15" y1="12" x2="3" y2="12" />
      </svg>
      <span>Login</span>
    </a>
  )}
</div>

---
interface Slide {
  image: { src: string; alt?: string };
  tagline?: string;
  title?: string;
  subtitle?: string;
  actions?: Array<{ text: string; href: string; variant?: 'primary' | 'secondary' | 'tertiary' }>;
}

export interface Props {
  id?: string;
  slides?: Slide[];
  autoplayInterval?: number;
  isDark?: boolean;
}

const {
  id = 'hero-carousel',
  slides = [],
  autoplayInterval = 5000,
  isDark = false,
} = Astro.props;
---

{slides.length > 0 && (
  <section
    id={id}
    class:list={['relative not-prose w-full overflow-hidden', { dark: isDark }]}
    data-hero-carousel
    data-autoplay={String(autoplayInterval)}
  >
    <div class="relative" data-carousel-track style={`height: clamp(420px, 70vh, 720px);`}>
      {slides.map((s, i) => (
        <div
          class:list={['absolute inset-0 transition-opacity duration-700 ease-in-out', i === 0 ? 'opacity-100 z-10' : 'opacity-0 z-0']}
          data-slide
          data-slide-index={i}
          aria-hidden={i !== 0}
        >
          {s.image?.src ? (
            <img
              src={s.image.src}
              alt={s.image.alt || s.title || ''}
              class="absolute inset-0 w-full h-full object-cover"
              loading={i === 0 ? 'eager' : 'lazy'}
              fetchpriority={i === 0 ? 'high' : 'auto'}
            />
          ) : (
            <div class="absolute inset-0 bg-gradient-to-br from-slate-700 to-slate-900"></div>
          )}
          <div class="absolute inset-0 bg-gradient-to-tr from-black/70 via-black/40 to-black/30"></div>
          <div class="relative h-full max-w-7xl mx-auto px-4 sm:px-6 flex items-center">
            <div class="max-w-3xl text-white">
              {s.tagline && (
                <p class="text-sm md:text-base font-semibold uppercase tracking-widest text-sky-300 mb-3" set:html={s.tagline} />
              )}
              {s.title && (
                <h1 class="text-3xl md:text-5xl lg:text-6xl font-bold leading-tight tracking-tight mb-4" set:html={s.title} />
              )}
              {s.subtitle && (
                <p class="text-base md:text-lg text-white/90 mb-6 max-w-2xl" set:html={s.subtitle} />
              )}
              {s.actions && s.actions.length > 0 && (
                <div class="flex flex-wrap gap-3">
                  {s.actions.map((a) => (
                    <a
                      href={a.href}
                      class:list={[
                        'inline-flex items-center font-semibold px-5 py-2.5 rounded-md text-sm transition',
                        a.variant === 'primary' || !a.variant
                          ? 'bg-sky-600 hover:bg-sky-700 text-white'
                          : a.variant === 'secondary'
                            ? 'bg-white text-slate-900 hover:bg-slate-100'
                            : 'border border-white/40 text-white hover:bg-white/10',
                      ]}
                    >
                      {a.text}
                    </a>
                  ))}
                </div>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>

    {slides.length > 1 && (
      <>
        <button
          type="button"
          data-carousel-prev
          aria-label="上一张"
          class="absolute left-3 md:left-6 top-1/2 -translate-y-1/2 z-20 w-10 h-10 md:w-12 md:h-12 rounded-full bg-black/40 hover:bg-black/60 text-white flex items-center justify-center"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
        </button>
        <button
          type="button"
          data-carousel-next
          aria-label="下一张"
          class="absolute right-3 md:right-6 top-1/2 -translate-y-1/2 z-20 w-10 h-10 md:w-12 md:h-12 rounded-full bg-black/40 hover:bg-black/60 text-white flex items-center justify-center"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </button>
        <div class="absolute bottom-4 md:bottom-6 left-1/2 -translate-x-1/2 z-20 flex gap-2">
          {slides.map((_, i) => (
            <button
              type="button"
              data-carousel-dot
              data-dot-index={i}
              aria-label={`跳到第 ${i + 1} 张`}
              class:list={['w-2.5 h-2.5 md:w-3 md:h-3 rounded-full transition', i === 0 ? 'bg-white' : 'bg-white/40 hover:bg-white/70']}
            />
          ))}
        </div>
      </>
    )}
  </section>
)}

<script is:inline>
  (function () {
    document.querySelectorAll('[data-hero-carousel]').forEach(function (root) {
      const slides = root.querySelectorAll('[data-slide]');
      if (slides.length < 2) return;
      const prev = root.querySelector('[data-carousel-prev]');
      const next = root.querySelector('[data-carousel-next]');
      const dots = root.querySelectorAll('[data-carousel-dot]');
      const autoplay = parseInt(root.getAttribute('data-autoplay') || '5000', 10);
      let idx = 0;
      let timer = null;
      let paused = false;

      function show(i) {
        idx = (i + slides.length) % slides.length;
        slides.forEach(function (s, j) {
          s.classList.toggle('opacity-100', j === idx);
          s.classList.toggle('opacity-0', j !== idx);
          s.classList.toggle('z-10', j === idx);
          s.classList.toggle('z-0', j !== idx);
          s.setAttribute('aria-hidden', String(j !== idx));
        });
        dots.forEach(function (d, j) {
          d.classList.toggle('bg-white', j === idx);
          d.classList.toggle('bg-white/40', j !== idx);
        });
      }
      function start() { stop(); if (autoplay > 0) timer = setInterval(function () { if (!paused) show(idx + 1); }, autoplay); }
      function stop() { if (timer) { clearInterval(timer); timer = null; } }

      if (prev) prev.addEventListener('click', function () { show(idx - 1); start(); });
      if (next) next.addEventListener('click', function () { show(idx + 1); start(); });
      dots.forEach(function (d) {
        d.addEventListener('click', function () {
          const i = parseInt(d.getAttribute('data-dot-index') || '0', 10);
          show(i); start();
        });
      });
      root.addEventListener('mouseenter', function () { paused = true; });
      root.addEventListener('mouseleave', function () { paused = false; });
      start();
    });
  })();
</script>

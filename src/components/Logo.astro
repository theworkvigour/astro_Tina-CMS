---
import branding from '~/data/site/branding.yaml';

const siteName = branding?.site_name?.trim() || 'Vectoflare';
const initial = (siteName || '').charAt(0).toUpperCase() || 'V';
const logoImage = branding?.logo_image?.trim() || '';
const logoAlt = branding?.logo_alt?.trim() || `${siteName} logo`;
---

<a href="/" class="flex items-center gap-2 group" aria-label={`${siteName} home`}>
  {logoImage ? (
    <img
      src={logoImage}
      alt={logoAlt}
      class="h-9 w-9 rounded-lg object-cover shadow-sm group-hover:shadow-md transition-shadow"
      loading="eager"
    />
  ) : (
    <span
      class="inline-flex items-center justify-center w-9 h-9 rounded-lg bg-gradient-to-br from-sky-500 to-blue-600 text-white font-black text-lg shadow-sm group-hover:shadow-md transition-shadow"
      aria-hidden="true"
    >
      {initial}
    </span>
  )}
  <span
    class="self-center text-xl md:text-xl font-bold text-gray-900 whitespace-nowrap dark:text-white tracking-tight"
  >
    {siteName}
  </span>
</a>

---
interface Props {
  prefix: string;
  data?: {
    title?: string;
    subtitle?: string;
    tagline?: string;
    columns?: number;
    stats?: Array<{ amount?: string; title?: string; icon?: string }>;
  };
}
const { prefix, data = {} } = Astro.props;
const d = data ?? {};
---
<div class="space-y-4" data-section-type="stats" data-prefix={prefix}>
  <div>
    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Title</label>
    <input type="text" name="title" value={d.title ?? ''} class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm" />
  </div>
  <div>
    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Subtitle</label>
    <textarea name="subtitle" rows="2" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm">{d.subtitle ?? ''}</textarea>
  </div>
  <div>
    <div class="flex items-center justify-between mb-2">
      <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">Stats (统计项)</label>
      <button type="button" data-add-stat class="text-xs text-blue-600 dark:text-blue-400 hover:underline">+ 添加统计</button>
    </div>
    <div data-stats-list class="space-y-3">
      {(d.stats ?? []).map((s) => (
        <div data-stat-row class="rounded-md border border-gray-200 dark:border-gray-700 p-3 space-y-2 bg-gray-50 dark:bg-gray-900/50">
          <div class="grid grid-cols-3 gap-2">
            <input type="text" name="statAmount" value={s.amount ?? ''} placeholder="数字 (如 2,400+)" class="px-3 py-1.5 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm" />
            <input type="text" name="statTitle" value={s.title ?? ''} placeholder="标签" class="px-3 py-1.5 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm" />
            <div class="flex gap-2">
              <input type="text" name="statIcon" value={s.icon ?? ''} placeholder="图标 (可选)" class="flex-1 px-3 py-1.5 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm" />
              <button type="button" data-remove-stat class="text-xs text-red-600 dark:text-red-400 hover:underline">删除</button>
            </div>
          </div>
        </div>
      ))}
    </div>
    <template data-stat-template>
      <div data-stat-row class="rounded-md border border-gray-200 dark:border-gray-700 p-3 space-y-2 bg-gray-50 dark:bg-gray-900/50">
        <div class="grid grid-cols-3 gap-2">
          <input type="text" name="statAmount" placeholder="数字 (如 2,400+)" class="px-3 py-1.5 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm" />
          <input type="text" name="statTitle" placeholder="标签" class="px-3 py-1.5 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm" />
          <div class="flex gap-2">
            <input type="text" name="statIcon" placeholder="图标 (可选)" class="flex-1 px-3 py-1.5 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm" />
            <button type="button" data-remove-stat class="text-xs text-red-600 dark:text-red-400 hover:underline">删除</button>
          </div>
        </div>
      </div>
    </template>
  </div>
</div>

---
interface Props {
  prefix: string;
  data?: {
    title?: string;
    subtitle?: string;
    tagline?: string;
    actions?: Array<{ text?: string; href?: string; variant?: string; icon?: string }>;
  };
}
const { prefix, data = {} } = Astro.props;
const d = data ?? {};
---
<div class="space-y-4" data-section-type="cta" data-prefix={prefix}>
  <div>
    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Tagline (可选)</label>
    <input type="text" name="tagline" value={d.tagline ?? ''} class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm" />
  </div>
  <div>
    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Title <span class="text-xs text-gray-500">(支持 HTML 标签)</span></label>
    <textarea name="title" rows="3" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 font-mono text-sm">{d.title ?? ''}</textarea>
  </div>
  <div>
    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Subtitle <span class="text-xs text-gray-500">(支持 HTML 标签)</span></label>
    <textarea name="subtitle" rows="3" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 font-mono text-sm">{d.subtitle ?? ''}</textarea>
  </div>
  <div>
    <div class="flex items-center justify-between mb-2">
      <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">Actions (按钮)</label>
      <button type="button" data-add-action class="text-xs text-blue-600 dark:text-blue-400 hover:underline">+ 添加按钮</button>
    </div>
    <div data-actions-list class="space-y-3">
      {(d.actions ?? []).map((a) => (
        <div data-action-row class="rounded-md border border-gray-200 dark:border-gray-700 p-3 space-y-2 bg-gray-50 dark:bg-gray-900/50">
          <div class="flex gap-2">
            <input type="text" name="actionText" value={a.text ?? ''} placeholder="按钮文字" class="flex-1 px-3 py-1.5 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm" />
            <button type="button" data-remove-action class="text-xs text-red-600 dark:text-red-400 hover:underline">删除</button>
          </div>
          <div class="grid grid-cols-3 gap-2">
            <input type="text" name="actionHref" value={a.href ?? ''} placeholder="链接 URL" class="px-3 py-1.5 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm" />
            <input type="text" name="actionVariant" value={a.variant ?? ''} placeholder="variant" class="px-3 py-1.5 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm" />
            <input type="text" name="actionIcon" value={a.icon ?? ''} placeholder="图标 (tabler:xxx)" class="px-3 py-1.5 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm" />
          </div>
        </div>
      ))}
    </div>
    <template data-action-template>
      <div data-action-row class="rounded-md border border-gray-200 dark:border-gray-700 p-3 space-y-2 bg-gray-50 dark:bg-gray-900/50">
        <div class="flex gap-2">
          <input type="text" name="actionText" placeholder="按钮文字" class="flex-1 px-3 py-1.5 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm" />
          <button type="button" data-remove-action class="text-xs text-red-600 dark:text-red-400 hover:underline">删除</button>
        </div>
        <div class="grid grid-cols-3 gap-2">
          <input type="text" name="actionHref" placeholder="链接 URL" class="px-3 py-1.5 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm" />
          <input type="text" name="actionVariant" placeholder="variant" class="px-3 py-1.5 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm" />
          <input type="text" name="actionIcon" placeholder="图标 (tabler:xxx)" class="px-3 py-1.5 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm" />
        </div>
      </div>
    </template>
  </div>
</div>

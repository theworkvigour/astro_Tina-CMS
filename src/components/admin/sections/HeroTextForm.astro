---
interface Props {
  prefix: string;
  data?: {
    tagline?: string;
    title?: string;
    subtitle?: string;
    content?: string;
  };
}
const { prefix, data = {} } = Astro.props;
const d = data ?? {};
---
<div class="space-y-4" data-section-type="hero_text" data-prefix={prefix}>
  <div>
    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Tagline</label>
    <input type="text" name="tagline" value={d.tagline ?? ''} class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900" />
  </div>
  <div>
    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Title <span class="text-xs text-gray-500">(支持 HTML 标签)</span></label>
    <textarea name="title" rows="3" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 font-mono text-sm">{d.title ?? ''}</textarea>
  </div>
  <div>
    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Subtitle <span class="text-xs text-gray-500">(支持 HTML 标签)</span></label>
    <textarea name="subtitle" rows="3" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 font-mono text-sm">{d.subtitle ?? ''}</textarea>
  </div>
  <div>
    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Content <span class="text-xs text-gray-500">(可选,支持 HTML 标签)</span></label>
    <textarea name="content" rows="4" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 font-mono text-sm">{d.content ?? ''}</textarea>
  </div>
</div>

---
interface Props {
  prefix: string;
  data?: {
    title?: string;
    subtitle?: string;
    testimonials?: Array<{
      title?: string;
      testimonial?: string;
      name?: string;
      job?: string;
      image?: { src?: string; alt?: string };
    }>;
  };
}
const { prefix, data = {} } = Astro.props;
const d = data ?? {};
---
<div class="space-y-4" data-section-type="testimonials" data-prefix={prefix}>
  <div>
    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Title</label>
    <input type="text" name="title" value={d.title ?? ''} class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm" />
  </div>
  <div>
    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Subtitle</label>
    <textarea name="subtitle" rows="2" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm">{d.subtitle ?? ''}</textarea>
  </div>
  <div>
    <div class="flex items-center justify-between mb-2">
      <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">Testimonials (评价)</label>
      <button type="button" data-add-testimonial class="text-xs text-blue-600 dark:text-blue-400 hover:underline">+ 添加评价</button>
    </div>
    <div data-testimonials-list class="space-y-3">
      {(d.testimonials ?? []).map((t) => (
        <div data-testimonial-row class="rounded-md border border-gray-200 dark:border-gray-700 p-3 space-y-2 bg-gray-50 dark:bg-gray-900/50">
          <div class="grid grid-cols-2 gap-2">
            <input type="text" name="testName" value={t.name ?? ''} placeholder="姓名" class="px-3 py-1.5 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm" />
            <input type="text" name="testJob" value={t.job ?? ''} placeholder="职位/描述" class="px-3 py-1.5 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm" />
          </div>
          <textarea name="testText" rows="3" placeholder="评价内容" class="w-full px-3 py-1.5 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm">{t.testimonial ?? ''}</textarea>
          <div class="grid grid-cols-2 gap-2">
            <input type="text" name="testImageSrc" value={t.image?.src ?? ''} placeholder="头像 URL" class="px-3 py-1.5 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm" />
            <div class="flex gap-2">
              <input type="text" name="testImageAlt" value={t.image?.alt ?? ''} placeholder="alt" class="flex-1 px-3 py-1.5 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm" />
              <button type="button" data-remove-testimonial class="text-xs text-red-600 dark:text-red-400 hover:underline">删除</button>
            </div>
          </div>
        </div>
      ))}
    </div>
    <template data-testimonial-template>
      <div data-testimonial-row class="rounded-md border border-gray-200 dark:border-gray-700 p-3 space-y-2 bg-gray-50 dark:bg-gray-900/50">
        <div class="grid grid-cols-2 gap-2">
          <input type="text" name="testName" placeholder="姓名" class="px-3 py-1.5 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm" />
          <input type="text" name="testJob" placeholder="职位/描述" class="px-3 py-1.5 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm" />
        </div>
        <textarea name="testText" rows="3" placeholder="评价内容" class="w-full px-3 py-1.5 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm"></textarea>
        <div class="grid grid-cols-2 gap-2">
          <input type="text" name="testImageSrc" placeholder="头像 URL" class="px-3 py-1.5 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm" />
          <div class="flex gap-2">
            <input type="text" name="testImageAlt" placeholder="alt" class="flex-1 px-3 py-1.5 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm" />
            <button type="button" data-remove-testimonial class="text-xs text-red-600 dark:text-red-400 hover:underline">删除</button>
          </div>
        </div>
      </div>
    </template>
  </div>
</div>
